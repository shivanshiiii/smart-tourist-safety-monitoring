# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Firebase (optional — leave blank to run on the built-in in-memory store)
# Create a service account in Firebase console > Project settings > Service accounts
# and paste the values below, OR point FIREBASE_SERVICE_ACCOUNT_PATH at the JSON file.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Twilio (optional — for real offline/SMS-based SOS relay)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
POLICE_CONTACT_NUMBER=

# Anomaly detection tuning
INACTIVITY_THRESHOLD_MIN=30
DEVIATION_THRESHOLD_METERS=750
SPEED_ANOMALY_KMH=140
